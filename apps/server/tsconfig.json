{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": ".", // Mudamos de "." para "src" para focar no teu código
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["node"] 
    },
    "include": [
        "src/**/*", // Garante que apanha subpastas
        "prisma.config.ts",
        "prisma/**/*.ts"
    ],
    "exclude": ["node_modules", "dist"] // Explicitamente ignorar estas pastas
}